generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELED
  EXPIRED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FeatureType {
  BOOLEAN
  NUMBER
  TEXT
}

enum Currency {
  BRL
  USD
  EUR
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model Plan {
  id String @id @default(uuid())

  code        String  @unique
  name        String
  description String?

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy     String?
  updatedBy     String?
  deletedBy     String?
  planPrices    PlanPrice[]
  planFeatures  PlanFeature[]
  subscriptions Subscription[]

  @@index([active])
  @@index([createdAt])
  @@map("plans")
}

model PlanPrice {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  price    Float
  currency Currency @default(BRL)

  billingCycle BillingCycle

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, billingCycle, currency])
  @@map("plan_prices")
}

model Feature {
  id String @id @default(uuid())

  name         String
  code         String      @unique
  description  String?
  type         FeatureType
  defaultValue String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id])

  value String

  @@unique([planId, featureId])
  @@map("plan_features")
}

model Subscription {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(TRIAL)

  startDate DateTime
  endDate   DateTime?

  canceledAt   DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company?

  @@index([status])
  @@map("subscriptions")
}

model Company {
  id String @id @default(uuid())

  subscriptionId String @unique

  corporateName String
  tradeName     String?

  document String  @unique
  email    String
  phone    String?

  status CompanyStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  subscription  Subscription     @relation(fields: [subscriptionId], references: [id])
  settings      CompanySettings?
  users         User[]
  units         Unit[]
  customers     Customer[]
  professionals Professional[]
  services      Service[]
  appointments  Appointment[]
  serviceOrders ServiceOrder[]

  @@index([status])
  @@index([createdAt])
  @@map("companies")
}

model CompanySettings {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

model User {
  id String @id @default(uuid())

  companyId String

  name         String
  email        String
  passwordHash String

  active Boolean @default(true)

  lastLoginAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company    @relation(fields: [companyId], references: [id])
  roles   UserRole[]

  @@unique([email, companyId])
  @@index([companyId])
  @@index([active])
  @@index([createdAt])
  @@map("users")
}

model Role {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  description String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@index([active])
  @@map("roles")
}

model Permission {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  description String?
  module      String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@index([active])
  @@index([module])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Unit {
  id String @id @default(uuid())

  companyId String

  name String
  code String

  document String?
  phone    String?
  email    String?

  address      String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  status CompanyStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company @relation(fields: [companyId], references: [id])

  professionals ProfessionalUnit[]
  appointments  Appointment[]
  serviceOrders ServiceOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("units")
}

model Customer {
  id String @id @default(uuid())

  companyId String

  name     String
  email    String?
  phone    String?
  document String?

  birthDate DateTime?

  notes String?

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company       Company        @relation(fields: [companyId], references: [id])
  appointments  Appointment[]
  serviceOrders ServiceOrder[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([name])
  @@index([phone])
  @@index([active])
  @@map("customers")
}

model Professional {
  id String @id @default(uuid())

  companyId String

  name     String
  email    String?
  phone    String?
  document String?

  specialty String?

  commissionRate Decimal? @db.Decimal(5, 2)

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company @relation(fields: [companyId], references: [id])

  units         ProfessionalUnit[]
  appointments  Appointment[]
  serviceOrders ServiceOrder[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([name])
  @@index([active])
  @@map("professionals")
}

model ProfessionalUnit {
  id String @id @default(uuid())

  professionalId String
  unitId         String

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])

  @@unique([professionalId, unitId])
  @@index([professionalId])
  @@index([unitId])
  @@map("professional_units")
}

model Service {
  id String @id @default(uuid())

  companyId String

  name        String
  description String?

  durationMinutes Int

  price           Decimal  @db.Decimal(10, 2)
  commissionType  String?
  commissionValue Decimal? @db.Decimal(10, 2)

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company           Company            @relation(fields: [companyId], references: [id])
  appointments      Appointment[]
  serviceOrderItems ServiceOrderItem[]

  @@index([companyId])
  @@index([name])
  @@index([active])
  @@map("services")
}

model Appointment {
  id String @id @default(uuid())

  companyId      String
  unitId         String
  customerId     String
  professionalId String
  serviceId      String

  startAt DateTime
  endAt   DateTime

  status AppointmentStatus @default(SCHEDULED)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  serviceOrder ServiceOrder?

  @@index([companyId])
  @@index([unitId])
  @@index([customerId])
  @@index([professionalId])
  @@index([startAt])
  @@index([status])
  @@map("appointments")
}

model ServiceOrder {
  id String @id @default(uuid())

  companyId String
  unitId    String

  appointmentId String? @unique

  customerId     String
  professionalId String

  status ServiceOrderStatus @default(OPEN)

  startedAt  DateTime?
  finishedAt DateTime?

  subtotal Decimal @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  items ServiceOrderItem[]

  @@index([companyId])
  @@index([unitId])
  @@index([customerId])
  @@index([professionalId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderItem {
  id String @id @default(uuid())

  serviceOrderId String
  serviceId      String

  quantity Int @default(1)

  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  @@index([serviceOrderId])
  @@index([serviceId])
  @@map("service_order_items")
}
