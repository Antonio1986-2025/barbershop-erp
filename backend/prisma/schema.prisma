generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELED
  EXPIRED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum FeatureType {
  BOOLEAN
  NUMBER
  TEXT
}

enum Currency {
  BRL
  USD
  EUR
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELED
  REFUNDED
}

enum CashTransactionType {
  ENTRY
  EXIT
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

enum ScheduleBlockType {
  UNIT
  PROFESSIONAL
}

enum FinancialCategoryType {
  INCOME
  EXPENSE
}

enum FinancialAccountType {
  RECEIVABLE
  PAYABLE
}

enum FinancialAccountStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_REMINDER
}

enum NotificationChannel {
  INTERNAL
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model Plan {
  id String @id @default(uuid())

  code        String  @unique
  name        String
  description String?

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy     String?
  updatedBy     String?
  deletedBy     String?
  planPrices    PlanPrice[]
  planFeatures  PlanFeature[]
  subscriptions Subscription[]

  @@index([active])
  @@index([createdAt])
  @@map("plans")
}

model PlanPrice {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  price    Float
  currency Currency @default(BRL)

  billingCycle BillingCycle

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, billingCycle, currency])
  @@map("plan_prices")
}

model Feature {
  id String @id @default(uuid())

  name         String
  code         String      @unique
  description  String?
  type         FeatureType
  defaultValue String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans PlanFeature[]

  @@map("features")
}

model PlanFeature {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id])

  value String

  @@unique([planId, featureId])
  @@map("plan_features")
}

model Subscription {
  id String @id @default(uuid())

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(TRIAL)

  startDate DateTime
  endDate   DateTime?

  canceledAt   DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company?

  @@index([status])
  @@map("subscriptions")
}

model Company {
  id String @id @default(uuid())

  subscriptionId String @unique

  corporateName String
  tradeName     String?

  document String  @unique
  email    String
  phone    String?

  status CompanyStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  subscription     Subscription      @relation(fields: [subscriptionId], references: [id])
  settings         CompanySettings?
  users            User[]
  units            Unit[]
  customers        Customer[]
  professionals    Professional[]
  services         Service[]
  appointments     Appointment[]
  serviceOrders    ServiceOrder[]
  cashRegisters    CashRegister[]
  payments         Payment[]
  cashTransactions CashTransaction[]
  categories       Category[]
  products         Product[]
  auditLogs        AuditLog[]
  businessHours    BusinessHour[]
  scheduleBlocks   ScheduleBlock[]
  notifications    Notification[]
  financialCategories FinancialCategory[]
  financialAccounts   FinancialAccount[]
  cashClosings        CashClosing[]

  @@index([status])
  @@index([createdAt])
  @@map("companies")
}

model CompanySettings {
  id String @id @default(uuid())

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  logoUrl        String?
  primaryColor   String?
  secondaryColor String?

  displayName   String?
  website       String?
  contactEmail  String?
  contactPhone  String?

  timezone  String?
  currency  String?
  dateFormat String?

  defaultAppointmentDuration Int?
  allowOnlineScheduling      Boolean?
  cancellationLimitHours     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_settings")
}

model User {
  id String @id @default(uuid())

  companyId String

  name         String
  email        String
  passwordHash String

  active Boolean @default(true)

  lastLoginAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company       Company         @relation(fields: [companyId], references: [id])
  roles         UserRole[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  notifications Notification[]

  @@unique([email, companyId])
  @@index([companyId])
  @@index([active])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id String @id @default(uuid())

  userId String

  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Role {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  description String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@index([active])
  @@map("roles")
}

model Permission {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  description String?
  module      String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]

  @@index([active])
  @@index([module])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Unit {
  id String @id @default(uuid())

  companyId String

  name String
  code String

  document String?
  phone    String?
  email    String?

  address      String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  status CompanyStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company @relation(fields: [companyId], references: [id])

  professionals    ProfessionalUnit[]
  appointments     Appointment[]
  serviceOrders    ServiceOrder[]
  cashRegisters    CashRegister[]
  payments         Payment[]
  cashTransactions CashTransaction[]
  stocks           Stock[]
  stockMovements   StockMovement[]
  businessHours    BusinessHour[]
  scheduleBlocks   ScheduleBlock[]
  cashClosings     CashClosing[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@map("units")
}

model BusinessHour {
  id String @id @default(uuid())

  companyId String
  unitId    String

  dayOfWeek Int
  startTime String
  endTime   String

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  @@unique([unitId, dayOfWeek])
  @@index([companyId])
  @@index([unitId])
  @@index([dayOfWeek])
  @@map("business_hours")
}

model ScheduleBlock {
  id String @id @default(uuid())

  companyId      String
  unitId         String
  professionalId String?

  title   String
  reason  String?

  type ScheduleBlockType @default(UNIT)

  startAt DateTime
  endAt   DateTime

  createdBy String

  createdAt DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])

  @@index([companyId])
  @@index([unitId])
  @@index([professionalId])
  @@index([startAt])
  @@map("schedule_blocks")
}

model Notification {
  id String @id @default(uuid())

  companyId String
  userId    String?
  customerId String?

  type    NotificationType
  channel NotificationChannel @default(INTERNAL)

  title   String
  message String

  status NotificationStatus @default(PENDING)

  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?

  metadata String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("notifications")
}

model Customer {
  id String @id @default(uuid())

  companyId String

  name     String
  email    String?
  phone    String?
  document String?

  birthDate DateTime?

  notes String?

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company       Company        @relation(fields: [companyId], references: [id])
  appointments  Appointment[]
  serviceOrders ServiceOrder[]
  notifications Notification[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([name])
  @@index([phone])
  @@index([active])
  @@map("customers")
}

model Professional {
  id String @id @default(uuid())

  companyId String

  name     String
  email    String?
  phone    String?
  document String?

  specialty String?

  commissionRate Decimal? @db.Decimal(5, 2)

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company @relation(fields: [companyId], references: [id])

  units          ProfessionalUnit[]
  appointments   Appointment[]
  serviceOrders  ServiceOrder[]
  scheduleBlocks ScheduleBlock[]

  @@unique([companyId, document])
  @@index([companyId])
  @@index([name])
  @@index([active])
  @@map("professionals")
}

model ProfessionalUnit {
  id String @id @default(uuid())

  professionalId String
  unitId         String

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])

  @@unique([professionalId, unitId])
  @@index([professionalId])
  @@index([unitId])
  @@map("professional_units")
}

model Service {
  id String @id @default(uuid())

  companyId String

  name        String
  description String?

  durationMinutes Int

  price           Decimal  @db.Decimal(10, 2)
  commissionType  String?
  commissionValue Decimal? @db.Decimal(10, 2)

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company           Company            @relation(fields: [companyId], references: [id])
  appointments      Appointment[]
  serviceOrderItems ServiceOrderItem[]

  @@index([companyId])
  @@index([name])
  @@index([active])
  @@map("services")
}

model Appointment {
  id String @id @default(uuid())

  companyId      String
  unitId         String
  customerId     String
  professionalId String
  serviceId      String

  startAt DateTime
  endAt   DateTime

  status AppointmentStatus @default(SCHEDULED)

  notes String?

  cancellationReason String?
  cancelledAt        DateTime?
  cancelledBy        String?

  rescheduledFromId String? @unique
  rescheduledTo     Appointment? @relation("RescheduledAppointments")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  rescheduledFrom Appointment? @relation("RescheduledAppointments", fields: [rescheduledFromId], references: [id])

  serviceOrder ServiceOrder?

  @@index([companyId])
  @@index([unitId])
  @@index([customerId])
  @@index([professionalId])
  @@index([startAt])
  @@index([status])
  @@map("appointments")
}

model ServiceOrder {
  id String @id @default(uuid())

  companyId String
  unitId    String

  appointmentId String? @unique

  customerId     String
  professionalId String

  status ServiceOrderStatus @default(OPEN)

  startedAt  DateTime?
  finishedAt DateTime?

  subtotal Decimal @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  items    ServiceOrderItem[]
  payments Payment[]

  @@index([companyId])
  @@index([unitId])
  @@index([customerId])
  @@index([professionalId])
  @@index([status])
  @@map("service_orders")
}

model ServiceOrderItem {
  id String @id @default(uuid())

  serviceOrderId String
  serviceId      String

  quantity Int @default(1)

  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])

  @@index([serviceOrderId])
  @@index([serviceId])
  @@map("service_order_items")
}

model CashRegister {
  id String @id @default(uuid())

  companyId String
  unitId    String

  openedBy String
  closedBy String?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  openingAmount Decimal  @db.Decimal(10, 2)
  closingAmount Decimal? @db.Decimal(10, 2)

  status CashRegisterStatus @default(OPEN)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  transactions CashTransaction[]
  closings     CashClosing[]

  @@index([companyId])
  @@index([unitId])
  @@index([status])
  @@map("cash_registers")
}

model Payment {
  id String @id @default(uuid())

  companyId String
  unitId    String

  serviceOrderId String

  amount Decimal @db.Decimal(10, 2)

  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  transactions CashTransaction[]

  @@index([companyId])
  @@index([unitId])
  @@index([serviceOrderId])
  @@index([status])
  @@map("payments")
}

model CashTransaction {
  id String @id @default(uuid())

  companyId String
  unitId    String

  cashRegisterId String

  paymentId String?

  type CashTransactionType

  amount Decimal @db.Decimal(10, 2)

  description String

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  unit    Unit    @relation(fields: [unitId], references: [id])

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([companyId])
  @@index([unitId])
  @@index([cashRegisterId])
  @@index([paymentId])
  @@map("cash_transactions")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REFRESH_TOKEN
  PAY
  CANCEL
  CLOSE_CASH
}

model AuditLog {
  id String @id @default(uuid())

  companyId String
  userId    String

  action   AuditAction
  entity   String
  entityId String?

  oldData String?
  newData String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Category {
  id String @id @default(uuid())

  companyId String

  name        String
  description String?

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company Company @relation(fields: [companyId], references: [id])

  products Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([active])
  @@map("categories")
}

model Product {
  id String @id @default(uuid())

  companyId  String
  categoryId String?

  name    String
  barcode String?

  costPrice Decimal @db.Decimal(10, 2)
  salePrice Decimal @db.Decimal(10, 2)

  active Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  company  Company   @relation(fields: [companyId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  stocks    Stock[]
  movements StockMovement[]

  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@index([name])
  @@index([active])
  @@map("products")
}

model Stock {
  id String @id @default(uuid())

  unitId    String
  productId String

  quantity Decimal @db.Decimal(10, 3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit    Unit    @relation(fields: [unitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([unitId, productId])
  @@index([unitId])
  @@index([productId])
  @@map("stocks")
}

model StockMovement {
  id String @id @default(uuid())

  unitId    String
  productId String

  type StockMovementType

  quantity Decimal @db.Decimal(10, 3)

  description String?

  createdAt DateTime @default(now())

  unit    Unit    @relation(fields: [unitId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([unitId])
  @@index([productId])
  @@index([type])
  @@map("stock_movements")
}

model FinancialCategory {
  id String @id @default(uuid())

  companyId String

  name String
  type FinancialCategoryType

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  accounts FinancialAccount[]

  @@unique([companyId, name, type])
  @@index([companyId])
  @@index([type])
  @@map("financial_categories")
}

model FinancialAccount {
  id String @id @default(uuid())

  companyId  String
  categoryId String

  description String

  type   FinancialAccountType
  status FinancialAccountStatus @default(OPEN)

  amount Decimal @db.Decimal(10, 2)

  dueDate DateTime
  paidAt  DateTime?

  paymentId String?

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company            @relation(fields: [companyId], references: [id])
  category FinancialCategory  @relation(fields: [categoryId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([type])
  @@map("financial_accounts")
}

model CashClosing {
  id String @id @default(uuid())

  companyId      String
  unitId         String
  cashRegisterId String

  openedAt DateTime
  closedAt DateTime?

  openingAmount Decimal @db.Decimal(10, 2)
  closingAmount Decimal? @db.Decimal(10, 2)
  expectedAmount Decimal? @db.Decimal(10, 2)
  difference     Decimal? @db.Decimal(10, 2)

  closedBy String?

  createdAt DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id])
  unit         Unit         @relation(fields: [unitId], references: [id])
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])

  @@index([companyId])
  @@index([unitId])
  @@index([closedAt])
  @@map("cash_closings")
}
